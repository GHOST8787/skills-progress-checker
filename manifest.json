{
  "manifest_version": 3,
  "name": "Skills 進度檢查",
  "version": "1.0.0",
  "description": "對照「Google 數位人才探索計畫」母清單，偵測 Google Skills 與 Skillshop 認證的完成進度，標出還沒做完的課。純讀取，不點擊、不送出任何資料。",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Skills 進度總表",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.skills.google/*",
        "https://www.cloudskillsboost.google/*",
        "https://skillshop.docebosaas.com/*"
      ],
      "js": ["master-list.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
